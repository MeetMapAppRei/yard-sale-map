# Optional: production site URL (no trailing slash) for canonical + og:url in the built index.html.
# Set in Vercel → Environment Variables for Production, or use .env.production.
# See .env.production.example
# VITE_SITE_URL=https://your-domain.com

# API rate limits (serverless /api/*) — per client IP, sliding window. Omit for defaults.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PARSE_MAX=20
# RATE_LIMIT_PARSE_WINDOW_MS=60000
# RATE_LIMIT_GEOCODE_MAX=60
# RATE_LIMIT_GEOCODE_WINDOW_MS=60000
